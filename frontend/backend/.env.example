# Variables de entorno — copia este archivo a .env y rellena los valores
# NUNCA subas el archivo .env a GitHub

# ─── Base de datos MySQL (Railway) ───────────────────────────────────────────
DB_HOST=your-railway-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=railway

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera uno seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS — dominio de tu frontend en Render ──────────────────────────────────
FRONTEND_URL=https://taller-de-sabores.onrender.com
